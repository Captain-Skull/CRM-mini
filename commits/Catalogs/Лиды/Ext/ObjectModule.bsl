
Процедура ПриЗаписи(Отказ)
	Если Не Отказ Тогда
		ДатаСейчас = ТекущаяДата();
			
		НаборЗаписей = РегистрыСведений.ИсторияЛидов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Лид.Установить(Ссылка);
		НаборЗаписей.Прочитать();
			
		Для Каждого Запись Из НаборЗаписей Цикл
				
			Если Запись.Вышел = Дата(1, 1, 1) Тогда
				Запись.Вышел = ДатаСейчас;
			КонецЕсли; 
			
		КонецЦикла;
		Запись = НаборЗаписей.Добавить();
		Запись.Лид = Ссылка;
		Запись.Попал = ДатаСейчас;
		Запись.Период = ДатаСейчас;
		
		Запись.Статус = Статус;
		НаборЗаписей.Записать();
	КонецЕсли;
КонецПроцедуры
